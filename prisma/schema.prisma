generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum FixtureStatus {
  UPCOMING
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}


enum BidType {
  RESULT
  SCORE
}


enum BidStatus {
  PENDING
  WON
  LOST
  VOID
}


enum TokenEntryType {
  INITIAL_BONUS
  BID_COST
  RESULT_WIN
  SCORE_WIN
  ADJUSTMENT
}
